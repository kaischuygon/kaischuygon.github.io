---
interface Props {
    variant ?: 'default' | 'blurry';
}

const {variant = 'default'} = Astro.props;
---

<div class:list={[variant == 'default' ? 'bg-primary-100 dark:bg-primary-900' : 'bg-blur', 'flex justify-center items-center p-2 gap-1 brutalist-outline text-primary-950 dark:text-primary-50 font-code']}>
    <slot />
</div>
